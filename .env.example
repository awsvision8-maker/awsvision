# Database (Neon PostgreSQL — get connection string from https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Public site URL for SEO (canonical, sitemap, Open Graph) — MUST be https://awsvision.com in production
NEXT_PUBLIC_SITE_URL="https://awsvision.com"

# Google Search Console verification (optional — paste meta tag content value)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Bing Webmaster Tools verification (optional)
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code

# Gmail SMTP (sending only — public site email is support@awsvision.com in site-config.ts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="AWS Vision <your-email@gmail.com>"
ADMIN_EMAIL=your-email@gmail.com

# Admin portal credentials (separate from client login)
ADMIN_PORTAL_EMAIL=admin@awsvision.com
ADMIN_PORTAL_PASSWORD=change-this-admin-password
