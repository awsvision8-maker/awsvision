# Database (Neon PostgreSQL — get connection string from https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Public site URL for SEO (canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://awsvision.com"

# Gmail SMTP (sending only — public site email is support@awsvision.com in site-config.ts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="AWS Vision <your-email@gmail.com>"
ADMIN_EMAIL=your-email@gmail.com
