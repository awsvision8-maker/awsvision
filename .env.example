# Database
DATABASE_URL="file:./dev.db"

# Gmail SMTP (sending only — public site email is support@awsvision.com in site-config.ts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="AWS Vision <your-email@gmail.com>"
ADMIN_EMAIL=your-email@gmail.com

# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/awsvision"
