generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String
  onlineId     String?  @unique
  kycStatus    String   @default("pending")
  profileType  String   @default("individual")
  kycData      String?
  ambassadorId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nonprofitProfile    NonprofitProfile?
  accounts            PortfolioAccount[]
  transactions        Transaction[]
  sessions            Session[]
  withdrawalRequests  WithdrawalRequest[]
  investmentAgreements InvestmentAgreement[]
  notifications         UserNotification[]
  ambassador          BrandAmbassador? @relation(fields: [ambassadorId], references: [id], onDelete: SetNull)

  @@index([ambassadorId])
}

model NonprofitProfile {
  id                    String @id @default(cuid())
  userId                String @unique
  user                  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationLegalName String
  dbaName               String?
  ein                   String
  organizationType      String
  yearEstablished       String
  missionStatement      String
  website               String?
  fundCapital           Float
  monthlyRate           Float
  representativeName    String
  representativeTitle   String
}

model PortfolioAccount {
  id                 String    @id
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountNumber      String
  type               String
  principal          Float
  monthlyRatePercent Float
  investmentPlanId   String?
  maturityDate       DateTime?
  status             String    @default("active")
  profitEligibleAt   DateTime?
  profitRateAmended  Boolean   @default(false)
  amendmentNote      String?
  createdAt          DateTime  @default(now())

  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String           @id
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     PortfolioAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        String
  amount      Float
  description String
  status      String           @default("completed")
  date        DateTime         @default(now())

  @@index([userId])
  @@index([accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  topic     String
  message   String
  createdAt DateTime @default(now())
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  listType  String
  email     String
  createdAt DateTime @default(now())

  @@unique([listType, email])
  @@index([listType])
}

model AppointmentRequest {
  id            String   @id @default(cuid())
  fullName      String
  phone         String?
  email         String
  preferredDate String?
  topic         String
  createdAt     DateTime @default(now())
}

model WithdrawalRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String
  amount    Float
  method    String
  reference String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([userId])
}

model InvestmentAgreement {
  id                 String   @id @default(cuid())
  agreementNumber    String   @unique
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId          String
  transactionId      String   @unique
  planId             String
  planName           String
  monthlyRatePercent Float
  termMonths         Int
  totalRoiPercent    Float
  depositAmount      Float
  totalPrincipal     Float
  accountNumber      String
  accountType        String
  issuedAt           DateTime @default(now())
  maturityDate       DateTime
  clientFirstName    String
  clientLastName     String
  clientEmail        String
  amendedAt          DateTime?
  amendmentNote      String?

  @@index([userId])
  @@index([accountId])
}

model NotificationBroadcast {
  id               String             @id @default(cuid())
  title            String
  message          String
  type             String             @default("info")
  scope            String
  recipientCount   Int
  durationDays     Int                @default(0)
  durationHours    Int                @default(0)
  expiresAt        DateTime
  adminId          String?
  createdAt        DateTime           @default(now())
  notifications    UserNotification[]

  @@index([createdAt])
  @@index([expiresAt])
}

model UserNotification {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  broadcastId String?
  broadcast   NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
  title       String
  message     String
  type        String                 @default("info")
  readAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime               @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, expiresAt])
}

model Admin {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         String         @default("admin")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  chats        ChatConversation[] @relation("AssignedAdmin")
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([token])
}

model ChatConversation {
  id              String        @id @default(cuid())
  visitorName     String
  visitorEmail    String
  userId          String?
  visitorIp       String?
  visitorCity     String?
  visitorRegion   String?
  visitorCountry  String?
  visitorLocation String?
  lastSeenAt      DateTime?
  humanTakeoverAt DateTime?
  status          String        @default("open")
  assignedToId    String?
  assignedTo      Admin?        @relation("AssignedAdmin", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  messages        ChatMessage[]

  @@index([status])
  @@index([updatedAt])
  @@index([lastSeenAt])
}

model VisitorPresence {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  userId         String?
  visitorName    String?
  visitorEmail   String?
  conversationId String?
  currentPath    String   @default("/")
  ipAddress      String?
  city           String?
  region         String?
  country        String?
  locationLabel  String?
  status         String   @default("website")
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([status, lastSeenAt])
  @@index([lastSeenAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     String
  senderName     String
  body           String
  createdAt      DateTime         @default(now())
  readAt         DateTime?

  @@index([conversationId])
  @@index([createdAt])
}

model BrandAmbassadorApplication {
  id         String           @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  phone      String
  city       String?
  state      String?
  linkedin   String?
  experience String?
  message    String
  status     String           @default("pending")
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime         @default(now())
  ambassador BrandAmbassador?

  @@index([status, createdAt])
  @@index([email])
}

model BrandAmbassador {
  id            String                     @id @default(cuid())
  applicationId String?                    @unique
  application   BrandAmbassadorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  username      String                      @unique
  email         String                      @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String
  referralCode  String                      @unique
  status        String                      @default("active")
  approvedAt    DateTime                    @default(now())
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  sessions      ManagerSession[]
  referrals     User[]

  @@index([referralCode])
  @@index([status])
}

model ManagerSession {
  id           String          @id @default(cuid())
  ambassadorId String
  ambassador   BrandAmbassador @relation(fields: [ambassadorId], references: [id], onDelete: Cascade)
  token        String          @unique
  expiresAt    DateTime
  createdAt    DateTime        @default(now())

  @@index([ambassadorId])
  @@index([token])
}
